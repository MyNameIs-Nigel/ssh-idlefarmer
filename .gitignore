# Build artifacts
/bin/
/dist/
*.exe
*.dll
*.so
*.dylib

# Go
/vendor/

# Runtime data (never commit secrets or host keys).
# NOTE: /data/ holds committed game content (crops.toml, balance.toml) and is
# embedded into the binary — it is intentionally NOT ignored.
/var/
*.db
*.sqlite
*.sqlite3

# SSH host key
ssh_host_key*
host_key*
*.pem

# Local env
.env
.env.*

# Local scratch (screenshots, probe captures, manual-test artifacts)
/temp/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
